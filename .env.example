# Template de configuración para ZonaUTP
# Copiar este archivo como .env y configurar las variables

# Base de datos
DB_HOST=localhost
DB_NAME=utplace_market
DB_USER=jasonpty
DB_PASS=jason27278

# Configuración de correo UTP
MAIL_HOST=smtp.utp.ac.pa
MAIL_PORT=587
MAIL_USERNAME=your_utp_email@utp.ac.pa
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls

# Configuración de la aplicación
APP_NAME=ZonaUTP
APP_URL=http://localhost/utplace-market/utplace-market/
APP_ENV=development

# Configuración de seguridad
JWT_SECRET=your_jwt_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here

# Configuración de uploads
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp

# URLs de redes sociales (si aplica)
FACEBOOK_URL=
INSTAGRAM_URL=
TWITTER_URL=

# Configuración de API externa (si aplica)
GOOGLE_MAPS_API_KEY=your_google_maps_key
